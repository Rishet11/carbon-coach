{
  "name": "carbon-coach",
  "version": "1.0.0",
  "private": true,
  "description": "CarbonCoach — a smart, contextual carbon-footprint awareness platform that understands, tracks, and helps individuals reduce their emissions.",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
